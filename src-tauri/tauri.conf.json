{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "The Blinking Guy",
  "version": "1.0.0",
  "identifier": "com.theblinkingguy.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "The Blinking Guy - Settings",
        "url": "settings.html",
        "width": 420,
        "height": 750,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "visible": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
